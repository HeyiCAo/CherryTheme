{
  "manifest_version": 3,
  "name": "Sakura Pixel Theme",
  "version": "1.0",
  "description": "Theme with sky-blue day and Klein-blue night, featuring pixel-style cherry blossoms",
  "permissions": ["alarms", "storage", "theme"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Sakura Theme"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      }
    }
  }
}
